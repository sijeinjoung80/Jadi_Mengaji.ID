# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# =========================================================================
# FIREBASE CONFIGURATION (FOR DEPLOYING TO VERCEL OR OUTSIDE AI STUDIO)
# =========================================================================
# Set these variables on your hosting provider (like Vercel) to connect the app
# to your own Firebase project instead of the default demo sandbox.

# 1. Your Firebase Project ID
FIREBASE_PROJECT_ID=""

# 2. Your Firebase Web App API Key
FIREBASE_API_KEY=""

# 3. Your Firebase Web App ID
FIREBASE_APP_ID=""

# 4. Your Firebase Database ID (Optional, leave blank for standard "(default)" database)
FIREBASE_DATABASE_ID=""

# 5. Your Firebase Auth Domain (Optional, defaults to project-id.firebaseapp.com)
FIREBASE_AUTH_DOMAIN=""

# 6. Your Firebase Storage Bucket (Optional, defaults to project-id.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=""

# 7. Your Firebase Messaging Sender ID (Optional)
FIREBASE_MESSAGING_SENDER_ID=""

# =========================================================================
# VERCEL / SEPARATE CLIENT HOSTING BACKEND ROUTING
# =========================================================================
# Points your separate client-side deployment (like Vercel) to the custom Express server URL
VITE_API_URL=""
